<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Portfolio</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Header -->
    <header>
        <div class="container">
            <h1>Shiva Rudhra</h1>
            <p>Web Developer | CodSoft Intern | Tech Enthusiast</p>
        </div>
    </header>

    <!-- About Section -->
    <section id="about">
        <div class="container">
            <h2>About Me</h2>

            <img src="profile.jpg" alt="My Photo" class="profile-img">

            <p>
                Hello! I'm Shiva Rudhra, a passionate web developer and
                currently working as an Intern at CodSoft. I enjoy creating
                responsive and user-friendly websites using HTML, CSS, and
                JavaScript. I am constantly learning new technologies and
                improving my development skills.
            </p>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills">
        <div class="container">
            <h2>My Skills</h2>

            <div class="skill-list">
                <span>HTML</span>
                <span>CSS</span>
                <span>JavaScript</span>
                <span>Python</span>
                <span>Java</span>
                <span>Responsive Design</span>
                <span>Git & GitHub</span>
            </div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects">
        <div class="container">
            <h2>Projects</h2>

            <div class="project-card">
                <img src="project1.jpg" alt="Project 1">
                <h3>Landing Page</h3>
                <p>
                    Designed a responsive landing page using HTML and CSS
                    with modern UI elements.
                </p>
            </div>

            <div class="project-card">
                <img src="project2.jpg" alt="Project 2">
                <h3>Calculator App</h3>
                <p>
                    Built a functional calculator using HTML, CSS, and
                    JavaScript with interactive features.
                </p>
            </div>

        </div>
    </section>

    <!-- Resume Section -->
    <section id="resume">
        <div class="container">
            <h2>Resume</h2>

            <a href="resume.pdf" download class="btn">
                Download Resume
            </a>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact">
        <div class="container">
            <h2>Contact Me</h2>

            <p>Email: yourmail@example.com</p>
            <p>Phone: +91 XXXXX XXXXX</p>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2025 Shiva Rudhra. All Rights Reserved.</p>
    </footer>

    <script src="script.js"></script>

</body>
</html>
