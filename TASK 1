<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tech Landing Page</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Navbar -->
    <header>
        <nav class="navbar">
            <div class="logo">TechBrand</div>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#services">Services</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>

    <!-- Hero Section -->
    <section class="hero" id="home">
        <div class="hero-content">
            <h1>Build Your Dream Website</h1>
            <p>Create modern and responsive websites with HTML, CSS & JavaScript.</p>
            <button id="startBtn">Get Started</button>
        </div>
    </section>

    <!-- Services -->
    <section class="services" id="services">
        <h2>Our Services</h2>
        <div class="service-container">
            <div class="card">
                <h3>Web Design</h3>
                <p>Creative and attractive website designs.</p>
            </div>

            <div class="card">
                <h3>Development</h3>
                <p>Fast and responsive web applications.</p>
            </div>

            <div class="card">
                <h3>SEO</h3>
                <p>Improve your website visibility online.</p>
            </div>
        </div>
    </section>

    <!-- About -->
    <section class="about" id="about">
        <h2>About Us</h2>
        <p>
            We help businesses create professional websites with modern
            technologies and user-friendly designs.
        </p>
    </section>

    <!-- Footer -->
    <footer id="contact">
        <p>&copy; 2026 TechBrand. All Rights Reserved.</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    line-height:1.6;
}

.navbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 60px;
    background:#111827;
    color:white;
}

.logo{
    font-size:28px;
    font-weight:bold;
}

.nav-links{
    display:flex;
    list-style:none;
}

.nav-links li{
    margin-left:20px;
}

.nav-links a{
    color:white;
    text-decoration:none;
    transition:0.3s;
}

.nav-links a:hover{
    color:#38bdf8;
}

.hero{
    height:90vh;
    background:linear-gradient(rgba(0,0,0,0.5),
    rgba(0,0,0,0.5)),
    url("https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=1200");
    background-size:cover;
    background-position:center;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    color:white;
}

.hero-content h1{
    font-size:55px;
    margin-bottom:20px;
}

.hero-content p{
    font-size:20px;
    margin-bottom:25px;
}

button{
    padding:12px 30px;
    border:none;
    background:#38bdf8;
    color:white;
    font-size:18px;
    border-radius:5px;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    background:#0284c7;
}

.services{
    padding:70px 50px;
    text-align:center;
    background:#f4f4f4;
}

.services h2{
    margin-bottom:30px;
    font-size:36px;
}

.service-container{
    display:flex;
    justify-content:center;
    gap:20px;
    flex-wrap:wrap;
}

.card{
    background:white;
    padding:25px;
    width:300px;
    border-radius:10px;
    box-shadow:0 4px 10px rgba(0,0,0,0.1);
    transition:0.3s;
}

.card:hover{
    transform:translateY(-10px);
}

.about{
    padding:70px 50px;
    text-align:center;
}

.about h2{
    margin-bottom:20px;
}

footer{
    background:#111827;
    color:white;
    text-align:center;
    padding:20px;
}
const button = document.getElementById("startBtn");

button.addEventListener("click", () => {
    alert("Welcome! Thanks for exploring our website.");
});
